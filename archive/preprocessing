import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import OneHotEncoder
from sklearn.compose import ColumnTransformer
from sklearn.ensemble import RandomForestRegressor
from sklearn.metrics import mean_absolute_error, r2_score

# 1. LOAD DATA
# Using 'r' before the path handles the backslashes in Windows correctly
path = r'archive\India Agriculture Crop Production.csv'

try:
    df = pd.read_csv(path)
    print("✅ Data loaded successfully!")
except FileNotFoundError:
    print(f"❌ Error: Could not find the file at {path}")
    exit()

# 2. CLEAN DATA
# Convert Production and Area to numeric (handling non-numeric strings)
df['Production'] = pd.to_numeric(df['Production'], errors='coerce')
df['Area'] = pd.to_numeric(df['Area'], errors='coerce')

# Drop rows where critical values are missing
df = df.dropna(subset=['Production', 'Area', 'State', 'Season', 'Crop'])

# 3. VERIFY COLUMNS
# This ensures we use the exact names present in YOUR CSV
print("Available Columns:", df.columns.tolist())

# Adjusting to the standard names in the Kaggle 'India Agriculture' dataset
# Based on your previous error, the column is 'State', not 'State_Name'
features = ['State', 'Season', 'Crop', 'Area']
target = 'Production'

X = df[features]
y = df[target]

# 4. PREPROCESSING (Encoding)
# The column names here MUST match the column names in X exactly
column_transformer = ColumnTransformer([
    ('encoder', OneHotEncoder(handle_unknown='ignore'), ['State', 'Season', 'Crop'])
], remainder='passthrough')

# 5. SPLIT DATA (Using a smaller sample if the dataset is huge for speed)
if len(df) > 100000:
    df = df.sample(n=100000, random_state=42) # Taking a subset to avoid memory crashes

X_encoded = column_transformer.fit_transform(X)
X_train, X_test, y_train, y_test = train_test_split(X_encoded, y, test_size=0.2, random_state=42)

# 6. BUILD & TRAIN MODEL
print("⏳ Training Random Forest... (This may take a minute)")
# Using n_jobs=-1 uses all your CPU cores to speed up training
model = RandomForestRegressor(n_estimators=50, max_depth=10, n_jobs=-1, random_state=42)
model.fit(X_train, y_train)

# 7. EVALUATE
predictions = model.predict(X_test)
r2 = r2_score(y_test, predictions)
mae = mean_absolute_error(y_test, predictions)

print("-" * 30)
print(f"🚀 Model Results:")
print(f"R2 Score: {round(r2, 4)}")
print(f"Mean Absolute Error: {round(mae, 2)}")
print("-" * 30)

# 8. SAVE A VISUAL FOR GITHUB
plt.figure(figsize=(10,6))
plt.scatter(y_test, predictions, alpha=0.3)
plt.xlabel("Actual Production")
plt.ylabel("Predicted Production")
plt.title("Actual vs Predicted Crop Production")
plt.savefig('model_performance.png')
print("✅ Performance plot saved as 'model_performance.png'")

# Get feature names from the transformer
ohe_features = list(column_transformer.named_transformers_['encoder'].get_feature_names_out())
all_features = ohe_features + ['Area'] # 'Area' was the remainder/passthrough

# Get importance from model
importances = model.feature_importances_

# Map them together
feature_importance_df = pd.DataFrame({'Feature': all_features, 'Importance': importances})
feature_importance_df = feature_importance_df.sort_values(by='Importance', ascending=False).head(10)

# Plot
plt.figure(figsize=(10,6))
sns.barplot(x='Importance', y='Feature', data=feature_importance_df)
plt.title("Top 10 Factors Influencing Crop Production")
plt.savefig('feature_importance.png')
print("✅ Feature Importance plot saved!")